# Pipeline data — all `data/<pipeline>/` contents are reproducible
# outputs of `scripts/download_*.py` and must never be committed.
# `.gitkeep` files are whitelisted to preserve directory structure
# after a fresh clone. `data/demo/` is whitelisted as the only in-repo
# dataset (synthetic fixtures for tests and offline demos).
data/*/**
!data/**/.gitkeep
!data/demo/**

# Audit artifacts
audit-results/
scripts/audit-prompts/

# Screenshots and images (large binary files)
*.png

# Local report artifacts in repository root
/*.pdf
/*.html

# Playwright MCP cache
.playwright-mcp/

# Archival snapshots — content-addressed raw copies of external sources,
# grabbed at ingestion time so fatos continuam verificáveis even if the
# portal muda de URL ou tira conteúdo do ar. Reproducible from the
# pipeline re-run; never commit.
archival/

# Claude plans
.claude/plans/
.claude/*.lock

# Local MCP runtime config (keep example only)
.mcp.json

# Internal assistant instruction files (must never be published)
CLAUDE.md
AGENTS.md
AGENTS*.md
frontend/
