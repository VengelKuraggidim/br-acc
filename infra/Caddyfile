{$DOMAIN} {
    # Note: this legacy infra/ deployment no longer ships a web UI.
    # The Fiscal Cidadao PWA is now served by nginx (see
    # docker-compose.prod.yml) which reverse-proxies /api/* directly to
    # the FastAPI `bracc-api` service. The Flask `backend/` intermediate
    # was deleted in 2026-04-18 (Fase 04.G) — see `git log -- backend/`
    # for historical reference. Keep this file only if you are deploying
    # the bracc-api alone behind Caddy.
    handle /api/* {
        reverse_proxy api:8000
    }

    handle /health {
        reverse_proxy api:8000
    }

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        Referrer-Policy strict-origin-when-cross-origin
    }
}
