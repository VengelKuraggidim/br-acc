{$DOMAIN} {
    # Note: this legacy infra/ deployment no longer ships a web UI.
    # The Fiscal Cidadao PWA is now served by the Fiscal Cidadao backend
    # (backend/app.py) in the root docker-compose.yml topology. Keep this
    # file only if you are deploying the bracc-api alone behind Caddy.
    handle /api/* {
        reverse_proxy api:8000
    }

    handle /health {
        reverse_proxy api:8000
    }

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        Referrer-Policy strict-origin-when-cross-origin
    }
}
