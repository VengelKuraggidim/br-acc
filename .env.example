# Domain (production)
DOMAIN=bracc.example.com

# Neo4j
# Dev defaults — for production with 40M+ nodes, use:
#   NEO4J_HEAP_INITIAL=4G  NEO4J_HEAP_MAX=8G  NEO4J_PAGECACHE=12G
# Requires server with 32GB+ RAM (recommended: 64GB)
# Do not use default password in production; set a strong NEO4J_PASSWORD.
NEO4J_PASSWORD=changeme
NEO4J_URI=bolt://localhost:7687
NEO4J_DATABASE=neo4j
NEO4J_HEAP_INITIAL=512m
NEO4J_HEAP_MAX=1G
NEO4J_PAGECACHE=512m

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info
APP_ENV=dev
# In production use a secret with >= 32 characters (e.g. openssl rand -hex 32).
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=1440
INVITE_CODE=
# Do not use CORS_ORIGINS=* when using cookies/credentials (allow_credentials).
CORS_ORIGINS=http://localhost:3000
# AUTH_COOKIE_NAME=bracc_session
# In production use true so the session cookie is sent only over HTTPS.
AUTH_COOKIE_SECURE=false
# AUTH_COOKIE_SAMESITE=lax  # or "strict" / "none"
# Set TRUST_PROXY_HEADERS=true when running behind a TLS-terminating reverse proxy.
# TRUST_PROXY_HEADERS=false
# Rate limits (slowapi syntax: "<count>/<interval>"). Anonymous vs authenticated.
# RATE_LIMIT_ANON=60/minute
# RATE_LIMIT_AUTH=300/minute
# Investigation share-link TTL (hours). Default 168 = 7 days.
# SHARE_TOKEN_TTL_HOURS=168
PRODUCT_TIER=community
PATTERNS_ENABLED=false
# Public mode: site accessible without login. Required for the Fiscal Cidadao
# deployment story ("qualquer um pode entrar"). Flip to false on internal
# builds where every consumer must register first.
PUBLIC_MODE=true
PUBLIC_ALLOW_PERSON=true
PUBLIC_ALLOW_ENTITY_LOOKUP=true
# Keep investigations closed in public mode — they create server-side state
# and would let anonymous visitors persist arbitrary records.
PUBLIC_ALLOW_INVESTIGATIONS=false
PATTERN_SPLIT_THRESHOLD_VALUE=80000
PATTERN_SPLIT_MIN_COUNT=3
PATTERN_SHARE_THRESHOLD=0.6
PATTERN_SRP_MIN_ORGS=5
PATTERN_INEXIG_MIN_RECURRENCE=3
PATTERN_MAX_EVIDENCE_REFS=50
# Pattern hardening thresholds (decision-complete contract).
# PATTERN_TEMPORAL_WINDOW_YEARS=4        # range 1..20
# PATTERN_MIN_CONTRACT_VALUE=100000      # BRL, >=0
# PATTERN_MIN_CONTRACT_COUNT=2           # >=1
# PATTERN_MIN_DEBT_VALUE=50000           # BRL, >=0
# PATTERN_MIN_RECURRENCE=2               # >=1
# PATTERN_MIN_DISCREPANCY_RATIO=0.30     # 0..1
# PATTERN_SAME_AS_MIN_CONFIDENCE=0.85    # 0..1
# PATTERN_PEP_MIN_CONFIDENCE=0.85        # 0..1

# Frontend (dev only — production uses Caddy reverse proxy with relative paths)
VITE_API_URL=http://localhost:8000
VITE_PUBLIC_MODE=true
VITE_PATTERNS_ENABLED=false

# Optional: Google Cloud (for Base dos Dados / TSE BigQuery)
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# Optional ETL source tokens
# WORLD_BANK_API_KEY=
# EU_SANCTIONS_TOKEN=

# === Fiscal Cidadao (backend + PWA) ===
# Portal da Transparencia (opcional - para emendas em tempo real)
# Cadastre em: https://portaldatransparencia.gov.br/api-de-dados/cadastrar-email
TRANSPARENCIA_API_KEY=
