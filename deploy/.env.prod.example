# === Fiscal Cidadao - Variáveis de Produção ===

# Domínio do seu app (trocar pelo seu domínio real)
DOMAIN=fiscalcidadao.example.com

# Neo4j
NEO4J_PASSWORD=TROCAR_POR_SENHA_FORTE_AQUI
NEO4J_HEAP_INITIAL=1G
NEO4J_HEAP_MAX=2G
NEO4J_PAGECACHE=1G

# BRACC API
JWT_SECRET_KEY=TROCAR_rodar_openssl_rand_hex_32
CORS_ORIGINS=https://fiscalcidadao.example.com
PUBLIC_MODE=true
PUBLIC_ALLOW_PERSON=true
PUBLIC_ALLOW_ENTITY_LOOKUP=true
APP_ENV=production
LOG_LEVEL=warning

# Backend Fiscal Cidadão
BRACC_API_URL=http://bracc-api:8000
